modules = ["nodejs-24", "postgresql-16", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0", "resend:1.0.0", "google-mail:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 22624
externalPort = 3000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
ZENODO_SANDBOX = "1"
ZENODO_CREATOR_NAME = "Dietz, Joel"
ZENODO_CREATOR_ORCID = "0009-0007-4948-9192"
